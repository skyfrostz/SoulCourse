APP_ENV=local
APP_NAME=subject-choice-forum
HTTP_PORT=8080
HTTP_HOST_PORT=8081
FRONTEND_PORT=5173
ADMIN_PORT=5175
VITE_API_BASE_URL=http://localhost:8081/api/v1

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=5432
POSTGRES_USER=forum
POSTGRES_PASSWORD=forum_dev_password
POSTGRES_DB=forum
POSTGRES_SSLMODE=disable

REDIS_ADDR=localhost:6379
REDIS_HOST_PORT=6380
REDIS_PASSWORD=
REDIS_DB=0

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5175,http://127.0.0.1:5175
JWT_SECRET=replace-me-before-production
ADMIN_TOKEN=replace-me-for-admin-panel
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin_dev_password
ADMIN_PASSWORD_HASH=

# 阿里云 SMTP 示例：SMTP_HOST=smtpdm.aliyun.com，465/TLS 或 587/STARTTLS
SMTP_HOST=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=选科知谈
SMTP_USE_TLS=true
SMTP_START_TLS=false
EMAIL_VERIFICATION_TTL_MINUTES=10
EMAIL_VERIFICATION_SUBJECT=选科知谈邮箱验证码

AI_API_KEY=
