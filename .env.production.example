APP_ENV=production
APP_NAME=选科π
HTTP_PORT=8080
HTTP_HOST_PORT=8080
FRONTEND_HOST_PORT=80
ADMIN_HOST_PORT=8082

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=forum
POSTGRES_PASSWORD=<生成一个强密码>
POSTGRES_DB=forum
POSTGRES_SSLMODE=disable

REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

CORS_ALLOWED_ORIGINS=https://subject314.<你的主域名>,https://admin.subject314.<你的主域名>
MEDIA_UPLOAD_DIR=uploads

JWT_SECRET=<用 openssl rand -hex 32 生成>
ADMIN_TOKEN=<用 openssl rand -hex 32 生成>
ADMIN_EMAIL=<后台管理员邮箱>
ADMIN_PASSWORD=
ADMIN_PASSWORD_HASH=<后台管理员密码的 bcrypt 哈希>

# 阿里云 SMTP 示例
SMTP_HOST=smtpdm.aliyun.com
SMTP_PORT=465
SMTP_USERNAME=<阿里云邮件推送 SMTP 用户名>
SMTP_PASSWORD=<阿里云邮件推送 SMTP 密码>
SMTP_FROM_EMAIL=<已验证发信地址>
SMTP_FROM_NAME=选科π
SMTP_USE_TLS=true
SMTP_START_TLS=false
EMAIL_VERIFICATION_TTL_MINUTES=10
EMAIL_VERIFICATION_SUBJECT=选科π邮箱验证码

AI_API_KEY=<你的 DeepSeek API 密钥>
AI_BASE_URL=https://api.deepseek.com/v1
AI_MODEL=deepseek-chat
