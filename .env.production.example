APP_ENV=production
APP_NAME=subject-choice-forum
HTTP_PORT=8080
HTTP_HOST_PORT=8080
FRONTEND_HOST_PORT=80

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=forum
POSTGRES_PASSWORD=<生成一个强密码>
POSTGRES_DB=forum
POSTGRES_SSLMODE=disable

REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

CORS_ALLOWED_ORIGINS=<你的域名，例如 https://example.com>

JWT_SECRET=<用 openssl rand -hex 32 生成>

AI_API_KEY=<你的 DeepSeek API 密钥>
AI_BASE_URL=https://api.deepseek.com/v1
AI_MODEL=deepseek-chat
